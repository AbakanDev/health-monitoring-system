<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:clipChildren="false">


    <LinearLayout
            android:id="@+id/bottom_bar_bg"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:background="#4FC3F7"
            android:orientation="horizontal"
            android:weightSum="7"
            app:layout_constraintBottom_toBottomOf="parent">


        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageButton android:id="@+id/btn_dashboard" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/img_dashboard" android:background="@android:color/transparent" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Xu Hướng" android:textColor="@android:color/white" android:textSize="9sp" />
        </LinearLayout>


        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageButton android:id="@+id/btn_history" android:layout_width="30dp" android:layout_height="24dp" android:src="@drawable/img_mask" android:background="@android:color/transparent" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lịch Sử"
                      android:textColor="@android:color/white" android:textSize="9sp"/>
        </LinearLayout>


        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageButton android:id="@+id/btn_epidemiology" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/img_needle" android:background="@android:color/transparent" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dịch Tễ" android:textColor="@android:color/white" android:textSize="9sp" />
        </LinearLayout>


        <Space android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageButton android:id="@+id/btn_health_form" android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/img_form" android:background="@android:color/transparent" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sức khoẻ" android:textColor="@android:color/white" android:textSize="9sp" />
        </LinearLayout>


        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageButton android:id="@+id/btn_xnc" android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/img_xnc" android:background="@android:color/transparent" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="XNC" android:textColor="@android:color/white" android:textSize="9sp" />
        </LinearLayout>


        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <ImageButton android:id="@+id/btn_help" android:layout_width="30dp" android:layout_height="30dp" android:src="@drawable/img_help" android:background="@android:color/transparent" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trợ Giúp" android:textColor="@android:color/white" android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>


    <ImageButton
            android:id="@+id/btn_qr_scan"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/qr_bg_white_circle"
            android:elevation="8dp"
            android:src="@drawable/img_qr"
            android:padding="15dp"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toBottomOf="@id/bottom_bar_bg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/bottom_bar_bg" />


</androidx.constraintlayout.widget.ConstraintLayout>
