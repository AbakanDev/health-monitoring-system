<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F0FAFE"
            android:fillViewport="true">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="80dp">

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giấy Khai Báo Xuất Nhập Cảnh"
                android:textColor="@color/bluewithcheckbox"
                android:textSize="22sp"
                android:textStyle="bold" />

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Vui lòng khai báo đầy đủ và trung thực thông tin"
                android:textColor="#6FBBE2"
                android:textSize="14sp"
                android:textStyle="bold" />

        <!-- Lịch sử xuất nhập cảnh -->
        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="24dp"
                android:layout_marginTop="16dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                <!-- Header -->
                <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#55CBF9"
                        android:padding="16dp">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lịch sử xuất nhập cảnh"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                </RelativeLayout>

                <!-- Text khi chưa có dữ liệu -->
                <TextView
                        android:id="@+id/tvChuaXuatNhapCanh"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Bạn chưa có lịch sử xuất nhập cảnh"
                        android:textColor="#EF5350"
                        android:textSize="16sp"
                        android:textStyle="italic"
                        android:gravity="center"
                        android:padding="16dp"
                        android:visibility="gone" />

                <!-- Scroll danh sách -->
                <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxHeight="240dp"
                        android:fillViewport="false">

                    <LinearLayout
                            android:id="@+id/layoutXuatNhapCanhContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                </ScrollView>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loại Cửa Khẩu "
                            android:textColor="@color/bluewithcheckbox"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="*"
                            android:textColor="#FF0000"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                </LinearLayout>

                <RadioGroup
                        android:id="@+id/rgLoaiCuaKhau"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                    <RadioButton
                            android:id="@+id/rbHangKhong"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hàng Không"
                            android:textColor="@color/bluelightgreen"
                            android:buttonTint="@color/bluelightgreen"
                            android:textStyle="bold"/>
                    <RadioButton
                            android:id="@+id/rbDatLien"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đất Liền"
                            android:textColor="@color/bluelightgreen"
                            android:buttonTint="@color/bluelightgreen"
                            android:textStyle="bold"/>
                    <RadioButton
                            android:id="@+id/rbDuongBien"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đường Biển"
                            android:textColor="@color/bluelightgreen"
                            android:buttonTint="@color/bluelightgreen"
                            android:textStyle="bold"/>
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông Tin Cửa Khẩu"
                        android:textColor="@color/bluewithcheckbox"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chọn Cửa Khẩu "
                            android:textColor="@color/bluelightgreen"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="*"
                            android:textColor="#FF0000"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                </LinearLayout>

                <Spinner
                        android:id="@+id/spnChonCuaKhau"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:layout_marginTop="4dp"
                        android:backgroundTint="#D3D3D3"
                        android:spinnerMode="dropdown"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trạng Thái Cửa Khẩu"
                        android:textColor="@color/bluelightgreen"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                <RadioGroup
                        android:id="@+id/rgTrangThaiCuaKhau"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                    <RadioButton
                            android:id="@+id/rbHoatDong"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hoạt Động"
                            android:textColor="@color/bluelightgreen"
                            android:buttonTint="@color/bluelightgreen"
                            android:textStyle="bold"/>
                    <RadioButton
                            android:id="@+id/rbNgungHoatDong"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ngừng Hoạt Động"
                            android:textColor="@color/bluelightgreen"
                            android:buttonTint="@color/bluelightgreen"
                            android:textStyle="bold"/>
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                android:layout_marginStart="4dp">

            <CheckBox
                    android:id="@+id/cbKhongCoCuaKhau"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/bluelightgreen" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nếu không có hãy nhấn nút này!"
                    android:textColor="@color/bluelightgreen"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="*"
                    android:textColor="#FF0000"
                    android:textSize="16sp"
                    android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:layout_marginStart="4dp">

            <CheckBox
                    android:id="@+id/cbCamKetXNC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/bluelightgreen" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tôi cam kết thông tin khai báo là đúng sự thật"
                    android:textColor="@color/bluelightgreen"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="*"
                    android:textColor="#FF0000"
                    android:textSize="16sp"
                    android:textStyle="bold" />
        </LinearLayout>

        <Button
                android:id="@+id/btnHoanTat2"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:text="HOÀN TẤT"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/darklightbluemint"
                app:cornerRadius="28dp" />

    </LinearLayout>
</ScrollView>